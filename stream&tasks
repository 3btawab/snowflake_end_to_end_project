use database ecommerce_db ;
use role data_engineer ; 
use warehouse compute_whs ;

-- streams
create stream if not exists raw_ordersstream 
on table raw.raw_orders 
append_only = true ;

create stream if not exists raw_customersstream
on table raw.raw_customers ;

create stream if not exists raw_productssstream
on table raw.raw_products ;

-- create staging table 

create table if not exists staging.stg_orders (
    order_id           varchar(36),
    customer_id        varchar(36),
    product_id         varchar(36),
    quantity           number(10,0),
    unit_price         number(12,4),
    discount           number(5,4),
    status             varchar(30),
    payment_method     varchar(30),
    shipping_address   varchar(500),
    order_date         DATE,
    shipped_date       DATE,
    _source_file       varchar,
    _load_timestamp    TIMESTAMP_NTZ,
    _processed_at      TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP()
);

create table if not exists staging.stg_customers (
    customer_id        VARCHAR(36),
    full_name          VARCHAR(200),
    email              VARCHAR(254),
    phone              VARCHAR(30),
    date_of_birth      DATE,
    gender             VARCHAR(10),
    city               VARCHAR(100),
    country            VARCHAR(100),
    loyalty_tier       VARCHAR(20),
    total_orders       NUMBER(10,0),
    lifetime_value     NUMBER(14,4),
    registered_at      TIMESTAMP_NTZ,
    _processed_at      TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP()
);

create table if not exists staging.stg_products (
    product_id         VARCHAR(36),
    product_name       VARCHAR(500),
    category           VARCHAR(100),
    subcategory        VARCHAR(100),
    brand              VARCHAR(100),
    cost_price         NUMBER(12,4),
    sell_price         NUMBER(12,4),
    stock_qty          NUMBER(10,0),
    supplier_id        VARCHAR(36),
    is_active          BOOLEAN,
    created_date       DATE,
    _processed_at      TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP()
);

-- tasks -- root task
create or replace task raw.root_task
warehouse = compute_whs
schedule ='10 m'
when 
  system$stream_has_data('ecommerce_db.raw_ordersstream')
  or system$stream_has_data('ecommerce_db.raw_customersstream')
  or system$stream_has_data('ecommerce_db.raw_productssstream') as
select 'Root ELT triggered: ' || current_timestamp();

--1child taskss

create task if not exists raw.load_stg_orderstasks
warehouse = compute_whs
after raw.root_task
as
merge into staging.stg_orders tgt
using (
select 
    order_id,
    customer_id,
    product_id,
    try_to_number(quantity)                    AS quantity,
    try_to_number(unit_price, 12, 4)           AS unit_price,
    coalesce(try_to_number(discount, 5, 4), 0) AS discount,
    upper(trim(status))                        AS status,
    lower(trim(payment_method))                 AS payment_method,
    trim(shipping_address)                       AS shipping_address,
    try_to_date(order_date)                    AS order_date,
    try_to_date(shipped_date)                  AS shipped_date,
    _source_file,
    _load_timestamp
from raw_ordersstream
where METADATA$ACTION = 'INSERT'
    AND order_id  IS NOT NULL
    AND try_to_number(quantity)         IS NOT NULL
    AND TRY_TO_NUMBER(unit_price, 12,4) IS NOT NULL
) src

ON tgt.order_id = src.order_id
WHEN NOT MATCHED THEN INSERT (
  order_id, customer_id, product_id, quantity, unit_price,
  discount, status, payment_method, shipping_address,
  order_date, shipped_date, _source_file, _load_timestamp
) VALUES (
  src.order_id, src.customer_id, src.product_id, src.quantity, src.unit_price,
  src.discount, src.status, src.payment_method, src.shipping_address,
  src.order_date, src.shipped_date, src._source_file, src._load_timestamp
);

--2child taskss

create task if not exists raw.load_stg_customerstasks
warehouse = compute_whs
after raw.root_task
as
merge into staging.stg_customers tgt
using (
select 
    raw_json:customer_id::VARCHAR(36)      AS customer_id,
    raw_json:full_name::VARCHAR(200)       AS full_name,
    LOWER(raw_json:email::VARCHAR(254))    AS email,
    raw_json:phone::VARCHAR(30)            AS phone,
    TRY_TO_DATE(raw_json:date_of_birth::VARCHAR) AS date_of_birth,
    raw_json:gender::VARCHAR(10)           AS gender,
    raw_json:address:city::VARCHAR(100)    AS city,
    raw_json:address:country::VARCHAR(100) AS country,
    raw_json:loyalty_tier::VARCHAR(20)     AS loyalty_tier,
    raw_json:total_orders::NUMBER(10)      AS total_orders,
    raw_json:lifetime_value::NUMBER(14,4)  AS lifetime_value,
    TRY_TO_TIMESTAMP_NTZ(raw_json:registered_at::VARCHAR) AS registered_at
  FROM raw_customersstream
WHERE METADATA$ACTION IN ('INSERT', 'UPDATE')
AND raw_json:customer_id IS NOT NULL
) src
ON tgt.customer_id = src.customer_id

WHEN MATCHED THEN UPDATE SET
  full_name      = src.full_name,
  email          = src.email,
  loyalty_tier   = src.loyalty_tier,
  lifetime_value = src.lifetime_value,
  _processed_at  = CURRENT_TIMESTAMP()
WHEN NOT MATCHED THEN INSERT (
  customer_id, full_name, email, phone, date_of_birth,
  gender, city, country, loyalty_tier, total_orders,
  lifetime_value, registered_at
) VALUES (
  src.customer_id, src.full_name, src.email, src.phone, src.date_of_birth,
  src.gender, src.city, src.country, src.loyalty_tier, src.total_orders,
  src.lifetime_value, src.registered_at
);

--2child taskss

create task if not exists raw.load_stg_productstasks
warehouse = compute_whs
after raw.root_task
as
merge into staging.stg_products tgt
using (
select
    product_id,
    product_name,
    category,
    subcategory,
    brand,
    TRY_TO_NUMBER(cost_price, 12, 4) AS cost_price,
    TRY_TO_NUMBER(sell_price, 12, 4) AS sell_price,
    TRY_TO_NUMBER(stock_qty)         AS stock_qty,
    supplier_id,
    TRY_TO_BOOLEAN(is_active)        AS is_active,
    TRY_TO_DATE(created_date)        AS created_date
FROM raw.raw_products
WHERE METADATA$ACTION IN ('INSERT', 'UPDATE')
AND product_id IS NOT NULL
) src
ON tgt.product_id = src.product_id
WHEN MATCHED THEN UPDATE SET
  sell_price  = src.sell_price,
  stock_qty   = src.stock_qty,
  is_active   = src.is_active,
  _processed_at = CURRENT_TIMESTAMP()
WHEN NOT MATCHED THEN INSERT (
  product_id, product_name, category, subcategory, brand,
  cost_price, sell_price, stock_qty, supplier_id, is_active, created_date
) VALUES (
  src.product_id, src.product_name, src.category, src.subcategory, src.brand,
  src.cost_price, src.sell_price, src.stock_qty, src.supplier_id,
  src.is_active, src.created_date
);

ALTER TASK RAW.load_stg_orderstasks    RESUME;
ALTER TASK RAW.load_stg_customerstasks RESUME;
ALTER TASK RAW.load_stg_productstasks  RESUME;
ALTER TASK RAW.root_task               RESUME;

SHOW TASKS IN DATABASE ECOMMERCE_DB;

EXECUTE TASK RAW.ROOT_TASK;
